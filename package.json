{
  "name": "demicod",
  "displayName": "DemiCod",
  "publisher": "Sudharsan Vanamali",
  "description": "Step-by-Step Code Presenter",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "demicod.addStep",
        "title": "Demicod: Add Selection as Step"
      },
      {
        "command": "demicod.startPresentation",
        "title": "Demicod: Start Presentation"
      },
      {
        "command": "demicod.clearSteps",
        "title": "Demicod: Clear All Steps"
      },
      {
        "command": "demicod.removeLastStep",
        "title": "Demicod: Remove Last Step"
      },
      {
        "command": "demicod.nextStep",
        "title": "Demicod: Next Step"
      },
      {
        "command": "demicod.previousStep",
        "title": "Demicod: Previous Step"
      },
      {
        "command": "demicod.endPresentation",
        "title": "Demicod: End Presentation"
      },
      {
        "command": "demicod.openKeyboardShortcuts",
        "title": "Demicod: Open Keyboard Shortcuts"
      }
    ],
    "keybindings": [
      {
        "command": "demicod.addStep",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorHasSelection"
      },
      {
        "command": "demicod.startPresentation",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter"
      },
      {
        "command": "demicod.nextStep",
        "key": "ctrl+shift+right",
        "mac": "cmd+shift+right"
      },
      {
        "command": "demicod.previousStep",
        "key": "ctrl+shift+left",
        "mac": "cmd+shift+left"
      },
      {
        "command": "demicod.endPresentation",
        "key": "ctrl+shift+escape",
        "mac": "cmd+shift+escape"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "demicod.addStep",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Demicod",
      "properties": {
        "demicod.stepSeparator": {
          "type": "string",
          "default": "\n",
          "description": "Separator inserted between accumulated steps during presentation."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.118.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
